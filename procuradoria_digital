<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Teste Prático | Analista de Projetos Sênior</title>
  <style>
    :root {
      --bg: #f7f6fb;
      --card: #ffffff;
      --text: #232129;
      --muted: #6d6878;
      --primary: #2f2938;
      --primary-light: #f1eef8;
      --accent: #7c5cff;
      --accent-dark: #5b3fd6;
      --purple-soft: #ede8ff;
      --danger: #b42318;
      --warning: #b54708;
      --moderate: #a16207;
      --success: #4b5563;
      --border: #e7e3ef;
      --shadow: 0 14px 34px rgba(38, 33, 48, 0.10);
      --critical-bg: #fff1f0;
      --high-bg: #fff4e6;
      --medium-bg: #fff9db;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background: radial-gradient(circle at top right, #efe9ff 0, transparent 34%), var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    header {
      position: relative;
      background: linear-gradient(135deg, #ffffff 0%, #f4f1fb 48%, #dfd6ff 100%);
      color: var(--text);
      padding: 96px 20px 54px;
      text-align: center;
      border-bottom: 1px solid var(--border);
    }

    .topbar {
      position: absolute;
      top: 18px;
      left: 24px;
      right: 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .attus-logo {
      width: min(240px, 52vw);
      height: auto;
      display: block;
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 10px 14px;
      box-shadow: 0 10px 28px rgba(35, 33, 41, 0.08);
    }

    .candidate-name {
      font-size: 14px;
      color: var(--muted);
      font-weight: 700;
      text-align: right;
    }

    header .badge {
      display: inline-block;
      background: var(--purple-soft);
      border: 1px solid #d8cdfd;
      color: var(--accent-dark);
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 18px;
    }

    header h1 {
      font-size: clamp(30px, 5vw, 48px);
      line-height: 1.15;
      margin-bottom: 16px;
      color: #1f1b28;
    }

    header p {
      max-width: 880px;
      margin: 0 auto;
      font-size: 18px;
      color: var(--muted);
    }

    .container {
      width: min(1120px, calc(100% - 32px));
      margin: -28px auto 64px;
    }

    .summary-card {
      background: var(--card);
      border-radius: 22px;
      box-shadow: var(--shadow);
      padding: 28px;
      margin-bottom: 24px;
      border: 1px solid var(--border);
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 22px;
    }

    .metric {
      background: #fbfaff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 18px;
    }

    .metric strong {
      display: block;
      font-size: 22px;
      color: var(--accent-dark);
      margin-bottom: 4px;
    }

    .metric span {
      color: var(--muted);
      font-size: 14px;
    }

    nav.tabs {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin: 24px 0;
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(247, 246, 251, 0.92);
      backdrop-filter: blur(10px);
      padding: 14px 0;
    }

    .tab-button {
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--primary);
      padding: 12px 18px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 700;
      transition: all 0.2s ease;
      box-shadow: 0 4px 14px rgba(35, 33, 41, 0.05);
    }

    .tab-button:hover,
    .tab-button.active {
      background: var(--accent);
      color: #ffffff;
      border-color: var(--accent);
      box-shadow: 0 10px 24px rgba(124, 92, 255, 0.22);
    }

    .tab-content {
      display: none;
      animation: fadeIn 0.25s ease-in-out;
    }

    .tab-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    section.card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 22px;
      box-shadow: var(--shadow);
      padding: 30px;
      margin-bottom: 24px;
    }

    h2 {
      color: var(--primary);
      font-size: 30px;
      margin-bottom: 10px;
    }

    h3 {
      color: var(--text);
      font-size: 22px;
      margin: 26px 0 12px;
    }

    h4 {
      color: var(--primary);
      font-size: 18px;
      margin: 20px 0 8px;
    }

    .lead {
      color: var(--muted);
      font-size: 17px;
      margin-bottom: 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0 24px;
      overflow: hidden;
      border-radius: 14px;
      border: 1px solid var(--border);
    }

    th, td {
      text-align: left;
      padding: 14px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }

    th {
      background: var(--primary-light);
      color: var(--primary);
      font-weight: 800;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .risk-critical td { background: var(--critical-bg); }
    .risk-high td { background: var(--high-bg); }
    

    .risk-matrix-layout {
      display: grid;
      grid-template-columns: 1.45fr 0.9fr;
      gap: 22px;
      align-items: start;
      margin: 16px 0 24px;
    }

    .risk-matrix-layout table {
      margin: 0;
    }

    .heatmap-card {
      background: #ffffff;
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 10px 24px rgba(35, 33, 41, 0.06);
    }

    .heatmap-title {
      font-weight: 800;
      color: var(--primary);
      margin-bottom: 10px;
      font-size: 16px;
    }

    .heatmap-grid {
      display: grid;
      grid-template-columns: 52px repeat(3, 1fr);
      grid-template-rows: repeat(4, 58px);
      gap: 6px;
      align-items: stretch;
    }

    .heatmap-axis {
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      color: var(--muted);
      font-weight: 700;
      text-align: center;
    }

    .heatmap-cell {
      border-radius: 12px;
      border: 1px solid rgba(35, 33, 41, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      padding: 6px;
      font-size: 12px;
      font-weight: 800;
      color: #231f20;
      min-height: 52px;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .heatmap-cell:hover {
      transform: scale(1.04);
      box-shadow: 0 6px 16px rgba(0,0,0,0.08);
    }
    }

    .heat-low { background: #e9f7ef; }
    .heat-medium { background: var(--medium-bg); }
    .heat-high { background: var(--high-bg); }
    .heat-critical { background: var(--critical-bg); }
    .heat-showstopper { background: #b42318; color: #ffffff; box-shadow: 0 8px 20px rgba(180, 35, 24, 0.24); }

    .risk-token {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 999px;
      background: rgba(255,255,255,0.74);
      border: 1px solid rgba(35, 33, 41, 0.12);
      font-size: 12px;
      font-weight: 900;
    }

    .heat-showstopper .risk-token {
      background: rgba(255,255,255,0.18);
      border-color: rgba(255,255,255,0.35);
      color: #ffffff;
    }

    .heatmap-legend {
      margin-top: 14px;
      display: grid;
      gap: 8px;
      font-size: 13px;
      color: var(--muted);
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .legend-dot {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      flex: 0 0 auto;
    }

    .legend-showstopper { background: #b42318; }
    .legend-critical { background: #ffb4ab; }
    .legend-high { background: #ffe1bd; }
    .legend-medium { background: #fff6bf; }
    .legend-low { background: #e9f7ef; }

    .pill {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      white-space: nowrap;
    }

    .critical { background: #ffe4e2; color: var(--danger); }
    .high { background: #ffead1; color: var(--warning); }
    .medium { background: #fff3bf; color: var(--moderate); }
    .low { background: #eeeeee; color: #374151; }

    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    .box {
      background: #fbfaff;
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 20px;
    }

    ul, ol {
      padding-left: 22px;
      margin: 12px 0;
    }

    li {
      margin-bottom: 8px;
    }

    .quote {
      border-left: 5px solid var(--accent);
      background: #f1edff;
      padding: 18px 20px;
      border-radius: 12px;
      margin: 22px 0;
      color: #3b2d73;
      font-weight: 700;
    }

    .decision-card {
      background: #f8f5ff;
      border: 1px solid #d8cdfd;
      border-radius: 18px;
      padding: 20px;
      margin-top: 18px;
    }

    .footer-note {
      text-align: center;
      color: var(--muted);
      font-size: 14px;
      margin-top: 30px;
    }


    .d0-panel {
      background: linear-gradient(135deg, #ffffff 0%, #f7f3ff 58%, #efe8ff 100%);
      border: 1px solid #d8cdfd;
      border-radius: 22px;
      padding: 24px;
      margin-top: 28px;
      box-shadow: 0 14px 30px rgba(124, 92, 255, 0.12);
    }
    .d0-title { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; flex-wrap: wrap; }
    .d0-badge { display: inline-flex; background: var(--accent); color: #fff; border-radius: 999px; padding: 6px 12px; font-size: 13px; font-weight: 800; white-space: nowrap; }
    .workflow-box { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 18px; margin: 22px 0; }
    .workflow-steps { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-top: 12px; }
    .workflow-step { background: #f1eef8; color: var(--primary); border: 1px solid #d8cdfd; border-radius: 999px; padding: 10px 14px; font-weight: 800; font-size: 14px; }
    .workflow-arrow { color: var(--accent-dark); font-weight: 900; font-size: 18px; }
    .insight-executivo { background: #2f2938; color: #fff; border-radius: 18px; padding: 20px; margin-top: 18px; box-shadow: 0 12px 28px rgba(47, 41, 56, 0.20); }
    .insight-executivo strong { color: #dfd6ff; }

    

      .risk-matrix-layout {
        grid-template-columns: 1fr;
      }

      section.card,
      .summary-card {
        padding: 22px;
      }

      th, td {
        font-size: 14px;
        padding: 12px;
      }
    }


    /* Destaques visuais específicos da Tarefa 3 */
    .tarefa3-card {
      position: relative;
      overflow: hidden;
    }

    .tarefa3-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 7px;
      background: linear-gradient(90deg, var(--accent), #9f7aea, #d8cdfd);
    }

    .tarefa3-card > h2 {
      margin-top: 8px;
    }

    .executive-table tbody tr:nth-child(odd) td {
      background: #fbfaff;
    }

    .executive-table tbody tr:hover td,
    .revenue-table tbody tr:hover td {
      background: #f4f1ff;
    }

    .block-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      border-radius: 999px;
      background: var(--accent);
      color: #ffffff;
      font-weight: 900;
      box-shadow: 0 8px 18px rgba(124, 92, 255, 0.22);
    }

    .theme-highlight {
      font-weight: 800;
      color: var(--primary);
    }

    .quote.executive-highlight {
      border-left: none;
      border: 1px solid #d8cdfd;
      background: linear-gradient(135deg, #f5f1ff 0%, #ffffff 100%);
      color: #2f255f;
      display: flex;
      gap: 14px;
      align-items: flex-start;
      box-shadow: 0 12px 26px rgba(124, 92, 255, 0.10);
    }

    .quote.executive-highlight::before {
      content: "💡";
      flex: 0 0 auto;
      width: 36px;
      height: 36px;
      border-radius: 999px;
      background: var(--accent);
      color: #ffffff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 18px rgba(124, 92, 255, 0.22);
    }

    .t3-box {
      background: linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
      border-top: 4px solid var(--accent);
      box-shadow: 0 10px 24px rgba(35, 33, 41, 0.06);
    }

    .t3-box h4 {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .t3-box li::marker {
      color: var(--accent-dark);
    }

    .revenue-table tbody tr:nth-child(1) td { background: #f0fdf4; }
    .revenue-table tbody tr:nth-child(2) td { background: #fff9db; }
    .revenue-table tbody tr:nth-child(3) td { background: #fff4e6; }
    .revenue-table tbody tr:nth-child(4) td { background: #f1edff; }

    .revenue-category {
      font-weight: 900;
      color: var(--primary);
      white-space: nowrap;
    }

    .decision-card.t3-decisions {
      background: linear-gradient(135deg, #f8f5ff 0%, #ffffff 100%);
      border: 1px solid #d8cdfd;
      box-shadow: 0 12px 26px rgba(124, 92, 255, 0.10);
    }

    .decision-card.t3-decisions h3 {
      margin-top: 0;
    }

    .decision-card.t3-decisions li {
      padding: 8px 10px;
      background: rgba(255,255,255,0.72);
      border: 1px solid var(--border);
      border-radius: 12px;
    }

    .final-forward {
      background: linear-gradient(135deg, #ffffff 0%, #f1edff 100%);
      border: 1px solid #d8cdfd;
      border-left: 6px solid var(--accent);
      border-radius: 18px;
      padding: 20px;
      color: var(--primary);
      font-weight: 700;
      box-shadow: 0 10px 24px rgba(35, 33, 41, 0.06);
    }

  </style>
</head>
<body>
  <header>
    <div class="topbar">
      <img class="attus-logo" src="logo.png" alt="Attus Procuradoria Digital" />
      <div class="candidate-name">Deise Simon | Teste Prático — Analista de Projetos Sênior<br>
      <a href="https://www.linkedin.com/in/deisesimongroehs/" target="_blank" style="color:#7c5cff; text-decoration:none; font-weight:600;">
        Acesse perfil linkedin
      </a></div>
    </div>
    <div class="badge">Teste Prático | Analista de Projetos Sênior</div>
    <h1>Gestão de Portfólio, Riscos e Recuperação de Projetos</h1>
    <p>Plano executivo para priorização, recuperação de implantação estadual e previsibilidade de receita em cenário de escassez de recursos, crise operacional e pressão comercial.</p>
  </header>

  <main class="container">
    <div class="summary-card">
      <h2>Problema Diagnosticado</h2>
      <p class="lead">Cenário: Você é o responsável por um portfólio de 3 grandes implantações estaduais. No momento, há uma escassez de recursos na equipe de desenvolvimento. Além disso, o suporte reportou um bug crítico em produção que afeta todos os clientes, enquanto o comercial pressiona pela entrega de uma nova funcionalidade para o fechamento de um novo contrato.</p>
      <div class="summary-grid">
        <div class="metric">
          <strong>3</strong>
          <span>Implantações estaduais em portfólio</span>
        </div>
        <div class="metric">
          <strong>Bug crítico</strong>
          <span>Afetando todos os clientes em produção</span>
        </div>
        <div class="metric">
          <strong>Alta pressão</strong>
          <span>Conflito entre operação, entrega e comercial</span>
        </div>
      </div>
    </div>

    <nav class="tabs" aria-label="Navegação entre tarefas">
      <button class="tab-button active" onclick="openTab('tarefa1', this)">Tarefa 1 | Riscos e Priorização</button>
      <button class="tab-button" onclick="openTab('tarefa2', this)">Tarefa 2 | Recuperação do Projeto</button>
      <button class="tab-button" onclick="openTab('tarefa3', this)">Tarefa 3 | Gestão de Crise</button>
    </nav>

    <div id="tarefa1" class="tab-content active">
      <section class="card">
        <h2>Tarefa 1 — Gestão de Riscos e Priorização</h2>

        <h3>Resumo Executivo da Decisão</h3>
        <div class="decision-card">
          <p><strong>Decisão recomendada:</strong> priorizar imediatamente a correção do bug crítico em produção, com realocação temporária de capacidade técnica e congelamento controlado de demandas não críticas até estabilização do ambiente.</p>
          <p><strong>Justificativa:</strong> o bug afeta todos os clientes, compromete a continuidade operacional, aumenta risco reputacional e pode gerar impacto direto em contratos, suporte, satisfação e retenção.</p>
        </div>

        <h3>Matriz de Riscos — Probabilidade x Impacto</h3>
        <div class="risk-matrix-layout">
          <table>
            <thead>
              <tr>
                <th>Risco</th>
                <th>Probabilidade (Base de Evidência)</th>
                <th>Impacto</th>
                <th>Classificação</th>
              </tr>
            </thead>
            <tbody>
              <tr class="risk-critical">
                <td><strong>R1</strong> — Bug crítico em produção afetando todos os clientes</td>
                <td>Alta (Já materializado em produção)</td>
                <td>Alto</td>
                <td><span class="pill critical">Crítico</span></td>
              </tr>
              <tr class="risk-critical">
                <td><strong>R2</strong> — Escassez de recursos na equipe de desenvolvimento</td>
                <td>Alta (Capacidade atual insuficiente)</td>
                <td>Alto</td>
                <td><span class="pill critical">Crítico</span></td>
              </tr>
              <tr class="risk-high">
                <td><strong>R3</strong> — Atraso nas três implantações estaduais</td>
                <td>Média (Dependências e backlog acumulado)</td>
                <td>Alto</td>
                <td><span class="pill high">Alto</span></td>
              </tr>
              <tr class="risk-high">
                <td><strong>R4</strong> — Pressão comercial por nova funcionalidade</td>
                <td>Alta (Demanda ativa do comercial)</td>
                <td>Médio/Alto</td>
                <td><span class="pill high">Alto</span></td>
              </tr>
              <tr class="risk-high">
                <td><strong>R5</strong> — Perda de confiança dos clientes por instabilidade e atrasos</td>
                <td>Média (Impacto progressivo percebido)</td>
                <td>Alto</td>
                <td><span class="pill high">Alto</span></td>
              </tr>
              <tr class="risk-medium">
                <td><strong>R6</strong> — Sobrecarga do time técnico e aumento de retrabalho</td>
                <td>Alta (Sobrecarga já observada na operação, com evidências de aumento de retrabalho e filas técnicas)</td>
                <td>Médio</td>
                <td><span class="pill medium">Moderado</span></td>
              </tr>
            </tbody>
          </table>

          <aside class="heatmap-card" aria-label="Gráfico de matriz de calor de riscos">
            <div class="heatmap-title">Matriz de Calor dos Riscos (Visão Executiva)</div>
            <div style="font-size:12px;color:var(--muted);margin-bottom:8px;">Probabilidade (horizontal) x Impacto (vertical)</div>
            <div class="heatmap-grid" style="border-top:1px solid var(--border);padding-top:6px;">
              <div></div>
              <div class="heatmap-axis">Baixa</div>
              <div class="heatmap-axis">Média</div>
              <div class="heatmap-axis">Alta</div>

              <div class="heatmap-axis">Alto<br>Impacto</div>
              <div class="heatmap-cell heat-medium"><span>Moderado</span></div>
              <div class="heatmap-cell heat-high"><span>Alto</span><span class="risk-token">R3</span><span class="risk-token">R5</span></div>
              <div class="heatmap-cell heat-showstopper" title="Zona crítica — atuação imediata"><span>Crítico</span><span class="risk-token">R1</span><span class="risk-token">R2</span></div>

              <div class="heatmap-axis">Médio<br>Impacto</div>
              <div class="heatmap-cell heat-low"><span>Baixo</span></div>
              <div class="heatmap-cell heat-medium"><span>Moderado</span></div>
              <div class="heatmap-cell heat-high"><span>Alto</span><span class="risk-token">R4</span><span class="risk-token">R6</span></div>

              <div class="heatmap-axis">Baixo<br>Impacto</div>
              <div class="heatmap-cell heat-low"><span>Baixo</span></div>
              <div class="heatmap-cell heat-low"><span>Baixo</span></div>
              <div class="heatmap-cell heat-medium"><span>Moderado</span></div>
            </div>
            <div class="heatmap-legend" style="border-top:1px solid var(--border);padding-top:10px;">
              <div class="legend-item"><span class="legend-dot legend-showstopper"></span><strong>R1</strong> Bug crítico em produção (já materializado) — ação imediata</div>
              <div class="legend-item"><span class="legend-dot legend-showstopper"></span><strong>R2</strong> Escassez de recursos (capacidade insuficiente)</div>
              <div class="legend-item"><span class="legend-dot legend-high"></span><strong>R3</strong> Atraso nas implantações estaduais</div>
              <div class="legend-item"><span class="legend-dot legend-high"></span><strong>R4</strong> Nova funcionalidade comercial</div>
